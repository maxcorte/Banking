# Copie ce fichier en .env (sur le serveur) et remplis-le.
# Ne le commite JAMAIS sur GitHub.

# Ton nom de domaine (celui offert par Hostinger, ou un sous-domaine).
# Exemple : DOMAIN=mabanque.online   ou   DOMAIN=app.mondomaine.com
DOMAIN=mets-ton-domaine-ici

DB_NAME=banking
DB_USER=banking
DB_PASSWORD=mets-un-mot-de-passe-base-solide

# Secret JWT : au moins 32 caractères aléatoires. Génère-en un NEUF pour la prod :
#   head -c 48 /dev/urandom | base64
JWT_SECRET=remplace-par-un-secret-aleatoire-de-32-caracteres-minimum

ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMoiUnAdminFort-2026

# --- E-mail (reinitialisation de mot de passe) ---
# Boite Hostinger sur ton domaine (Business Email). Reglages SMTP sortant :
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=noreply@maximedelcorte.cloud
MAIL_PASSWORD=le-mot-de-passe-de-la-boite-noreply
# Expediteur : la meme adresse Hostinger.
MAIL_FROM=noreply@maximedelcorte.cloud
# Port 465 => SSL direct (true) et STARTTLS desactive (false).
MAIL_SSL=true
MAIL_STARTTLS=false
# URL publique (sert a construire le lien de reinitialisation).
APP_BASE_URL=https://maximedelcorte.cloud
